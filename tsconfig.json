{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "ignoreDeprecations": "6.0",
    "paths": {
      "@cli-skill/browser-recorder": ["packages/browser-recorder/src/index.ts"]
    }
  }
}
