#!/usr/bin/env bun

import { spawn } from "node:child_process";

const child = spawn("cli-skill", ["__SKILL_NAME__", ...process.argv.slice(2)], {
  stdio: "inherit",
  env: process.env,
});

child.on("exit", (code, signal) => {
  if (signal) {
    process.kill(process.pid, signal);
    return;
  }

  process.exit(code ?? 0);
});
