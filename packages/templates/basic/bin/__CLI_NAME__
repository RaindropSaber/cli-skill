#!/usr/bin/env bun

import { resolveSkillRoot, runCli } from "@cli-skill/core";
import skill from "../src/index.ts";

runCli(skill, process.argv.slice(2), { rootDir: resolveSkillRoot(import.meta.url) }).then((exitCode) => {
  process.exitCode = exitCode;
}).catch((error) => {
  console.error(error);
  process.exit(1);
});
